# DAISy Monitoring Stack Environment Variables
# Copy to .env and fill in values before deploying
#
# cp .env.example .env
# vim .env

# ─── Deployment ───
DEPLOY_ENV=staging

# ─── Application Ports ───
# Must match the GitHub environment variables for the target environment
# (sourced from ${{ vars.OPENCLAW_GATEWAY_PORT }} in CI/CD)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# ─── Grafana ───
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-to-secure-password

# ─── Alert Channels ───
# Slack incoming webhook URL for #daisy-alerts channel
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ntfy.sh topic (reuse existing auth-monitor topic or create new)
NTFY_TOPIC=daisy-alerts

# PagerDuty Events API v2 routing key (for critical alerts)
PAGERDUTY_SERVICE_KEY=

# ─── Dead Man's Switch ───
# URL where Alertmanager sends Watchdog heartbeats
HEARTBEAT_WEBHOOK_URL=http://localhost:9099/heartbeat

# ─── Cloud Function (external heartbeat) ───
# Set these in the Cloud Function env vars, not here
# VM_HEALTH_URL=http://your-vm-internal-ip:${OPENCLAW_GATEWAY_PORT}/healthz
# ALERTMANAGER_URL=http://your-vm-internal-ip:9093
