{
  "annotations": {
    "list": [
      {
        "datasource": "Loki",
        "enable": true,
        "expr": "{source=\"falco\"} |~ \"CRITICAL|ALERT\"",
        "iconColor": "red",
        "name": "Security Events",
        "tagKeys": "rule",
        "titleFormat": "Falco: {{rule}}"
      }
    ]
  },
  "description": "DAISy-Agency Monitoring — Agent Activity, Security Events, Container Resources",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "🛡️ Security Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Falco Security Events (24h)",
      "type": "stat",
      "datasource": "Loki",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "expr": "count_over_time({source=\"falco\"} [24h])",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "title": "Watchdog Alerts (24h)",
      "type": "stat",
      "datasource": "Loki",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count_over_time({source=\"watchdog\", severity=~\"warning|critical\"} [24h])",
          "legendFormat": "Alerts"
        }
      ]
    },
    {
      "title": "Active Containers",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 12 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(container_start_time_seconds{name=~\"openclaw.*|sandbox.*\"})",
          "legendFormat": "Containers"
        }
      ]
    },
    {
      "title": "Gateway Uptime",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job=\"openclaw-gateway\"}[24h])",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "title": "📊 Container Resources",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"openclaw.*|sandbox.*\"}[5m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"openclaw.*|sandbox.*\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "title": "Container Network TX (bytes/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"openclaw.*|sandbox.*\"}[5m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "title": "Host Disk Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}",
          "legendFormat": "Root (/)"
        },
        {
          "expr": "1 - node_filesystem_avail_bytes{mountpoint=~\"/var/lib/daisy|/data\"} / node_filesystem_size_bytes{mountpoint=~\"/var/lib/daisy|/data\"}",
          "legendFormat": "Data"
        }
      ]
    },
    {
      "title": "🔍 Security Events Timeline",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "Falco Events",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{source=\"falco\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "📝 Agent Tool Invocations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false
    },
    {
      "title": "Tool Invocations (Audit Trail)",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{source=\"watchdog\", event_type=\"tool_invocation\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Watchdog Alerts",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{source=\"watchdog\", severity=~\"warning|critical\"}",
          "legendFormat": ""
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["daisy", "monitoring", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DAISy Agent Monitoring",
  "uid": "daisy-agent-overview",
  "version": 1
}
