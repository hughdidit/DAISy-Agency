{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "openclaw_session_state_total{state=\"active\"}",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Messages Processed / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(openclaw_message_processed_total[5m]) * 60",
          "legendFormat": "msg/min"
        }
      ]
    },
    {
      "title": "Webhooks Received / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(openclaw_webhook_received_total[5m]) * 60",
          "legendFormat": "webhooks/min"
        }
      ]
    },
    {
      "title": "Gateway Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"openclaw-otel\"}",
          "legendFormat": "Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Run Attempts Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(openclaw_run_attempt_total[5m]) * 60",
          "legendFormat": "runs/min"
        }
      ]
    },
    {
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(openclaw_tokens_total{type=\"input\"}[5m]) * 60",
          "legendFormat": "Input tokens/min"
        },
        {
          "expr": "rate(openclaw_tokens_total{type=\"output\"}[5m]) * 60",
          "legendFormat": "Output tokens/min"
        }
      ]
    },
    {
      "title": "Estimated Cost (USD/hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(openclaw_cost_usd_total[1h]) * 3600",
          "legendFormat": "$/hr"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Webhook Errors",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(openclaw_webhook_error_total[5m]) * 60",
          "legendFormat": "errors/min"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "openclaw_queue_depth",
          "legendFormat": "Queue depth"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["daisy", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Agent Activity Overview",
  "uid": "daisy-agent-activity"
}
