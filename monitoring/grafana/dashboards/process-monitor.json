        {
          "expr": "container_processes{name=~\".*openclaw.*\"}",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "title": "Container Thread Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_threads{name=~\".*openclaw.*\"}",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "title": "Process Allowlist Violations",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"watchdog\", event_type=\"process_violation\"}",
          "legendFormat": ""
