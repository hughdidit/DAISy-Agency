# DAISy-Agency Monitoring Stack — Environment Variables
# Copy to .env.monitoring and fill in values.
# This file MUST be root-owned with 600 permissions on the VM.
# NEVER commit .env.monitoring to git.

# ── Grafana ──────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme

# ── Discord Alerts ───────────────────────────────────────────────────
# Create a webhook in your Discord server → channel settings → integrations
DISCORD_ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Email Alerts ─────────────────────────────────────────────────────
ALERT_EMAIL_TO=alerts@example.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_FROM=daisy-alerts@example.com
ALERT_SMTP_USERNAME=your-smtp-username
ALERT_SMTP_PASSWORD=your-smtp-password

# ── OTel Collector (set in the application .env, not here) ───────────
# Add this to your application's .env file to enable OTLP export:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
