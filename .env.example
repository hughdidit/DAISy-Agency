# ──────────────────────────────────────────────────────────
# Required — docker-compose.yml will fail without these
# ──────────────────────────────────────────────────────────

# Gateway auth token (generated via: moltbot doctor --generate-gateway-token)
CLAWDBOT_GATEWAY_TOKEN=

# Claude session key (from browser cookies)
CLAUDE_AI_SESSION_KEY=

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Anthropic API key
ANTHROPIC_API_KEY=

# Gateway port (HTTP + WebSocket)
CLAWDBOT_GATEWAY_PORT=18789

# Bridge port (gateway port + 1)
CLAWDBOT_BRIDGE_PORT=18790

# Config directory (mounted as ~/.clawdbot inside container)
CLAWDBOT_CONFIG_DIR=

# Workspace directory (mounted as ~/clawd inside container)
CLAWDBOT_WORKSPACE_DIR=

# ──────────────────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────────────────

# Docker image reference (deploy.sh sets this; defaults to moltbot:local)
#CLAWDBOT_IMAGE=moltbot:local

# Usage monitoring (Claude web session)
#CLAUDE_WEB_SESSION_KEY=
#CLAUDE_WEB_COOKIE=

# Extension config — these are read from the moltbot config file, not
# passed through docker-compose.yml. Listed here for deployment reference.
#MONGODB_URI=
#OPENAI_API_KEY=
#BRAVE_API_KEY=

# Gateway bind mode: loopback (default) | lan | tailnet | custom
#CLAWDBOT_GATEWAY_BIND=loopback

# Twilio credentials (voice-call extension)
#TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#TWILIO_AUTH_TOKEN=
#TWILIO_WHATSAPP_FROM=whatsapp:+17343367101

# ──────────────────────────────────────────────────────────
# Platform / Discord allowlists (set in GitHub environment
# secrets for CI/CD; not needed for local dev)
# ──────────────────────────────────────────────────────────
#DISCORD_ALLOWED_GUILD_IDS=
#DISCORD_ALLOWED_CHANNEL_IDS=
#DISCORD_ALLOWED_USER_IDS=
#DISCORD_STRICT_ALLOWLIST=true
